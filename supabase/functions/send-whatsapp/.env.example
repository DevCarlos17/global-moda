# Variables de entorno para la Edge Function send-whatsapp
# Configúralas en: Dashboard Supabase → Edge Functions → Secrets

# CallMeBot — https://www.callmebot.com/blog/free-api-whatsapp-messages/
# Paso 1: Agrega +1 (34) 644 60 49 48 a tus contactos como "CallMeBot"
# Paso 2: Envía "I allow callmebot to send me messages" por WhatsApp a ese número
# Paso 3: Recibirás tu apikey por WhatsApp en unos segundos
WHATSAPP_RECIPIENT_NUMBER=5491100000000   # tu número en formato internacional, sin +
WHATSAPP_CALLMEBOT_APIKEY=123456          # la apikey que te envió CallMeBot

# Estas las provee Supabase automáticamente — no hace falta configurarlas
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=
